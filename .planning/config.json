{
  "runtime": "codex",
  "resolve_model_ids": "omit",
  "mode": "interactive",
  "granularity": "coarse",
  "model_profile": "budget",
  "workflow": {
    "research": false,
    "plan_check": false,
    "verifier": true,
    "auto_advance": false,
    "nyquist_validation": true,
    "pattern_mapper": true,
    "ai_integration_phase": true,
    "ui_phase": true,
    "ui_safety_gate": true,
    "tdd_mode": false,
    "code_review": false,
    "code_review_depth": "standard",
    "ui_review": false,
    "use_worktrees": false,
    "plan_chunked": true,
    "research_before_questions": false,
    "text_mode": true,
    "skip_discuss": false
  },
  "parallelization": {
    "enabled": false,
    "plan_level": false,
    "task_level": false,
    "skip_checkpoints": false,
    "max_concurrent_agents": 1,
    "min_plans_for_parallel": 2
  },
  "planning": {
    "commit_docs": true,
    "search_gitignored": false,
    "sub_repos": []
  },
  "git": {
    "branching_strategy": "none",
    "base_branch": null,
    "phase_branch_template": "gsd/phase-{phase}-{slug}",
    "milestone_branch_template": "gsd/{milestone}-{slug}",
    "quick_branch_template": null
  },
  "hooks": {
    "context_warnings": true,
    "workflow_guard": true
  },
  "manager": {
    "flags": {
      "discuss": "--text",
      "plan": "--text",
      "execute": ""
    }
  },
  "project_code": "DIP",
  "phase_naming": "sequential",
  "response_language": "Russian"
}
